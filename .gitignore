# ==========================================
# Operating System & Common Junk
# ==========================================
.DS_Store
.DS_Store?
._*
Thumbs.db
desktop.ini

# ==========================================
# IDEs and Code Editors
# ==========================================
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ==========================================
# Python / Django Backend
# ==========================================
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual Environments
venv/
.venv/
env/
.env/
ENV/
htmlcov/
.tox/
.coverage
.coverage.*
.pytest_cache/
.cache/

# Django specific
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal

# Django Media and Static collected folders
# (Keep media ignored; staticfiles can be rebuilt on build/deploy)
/media/
/staticfiles/

# ==========================================
# Node / React Frontend
# ==========================================
# Dependencies
node_modules/
/.pnp
.pnp.js

# Testing
/coverage

# Production Build Outputs (Vite, CRA, Next, etc.)
dist/
build/
out/
.next/

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ==========================================
# Secrets and Environment Variables
# ==========================================
# Never commit your active secrets!
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env
